# Usa a imagem do Node.js
FROM node:20-alpine

# Define a pasta de trabalho dentro do contêiner
WORKDIR /app

# Copia apenas os arquivos de pacotes primeiro (otimiza a instalação)
COPY package*.json ./

# Instala as dependências
RUN npm install

# Copia todo o resto do seu código
COPY . .

# Expõe a porta que o Next.js usa
EXPOSE 3000

# Comando para iniciar o Next.js em modo desenvolvimento
CMD ["npm", "run", "dev"]